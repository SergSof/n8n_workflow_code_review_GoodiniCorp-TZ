    {
      "parameters": {
        "jsCode": "const body = $input.first().json.body || {};\nconst email = (body.email || '').trim().toLowerCase();\nconst password = body.password || '';\nconst name = body.name || '';\n\nif (!email || !email.includes('@')) {\n  throw new Error('Invalid email');\n}\nif (password.length < 6) {\n  throw new Error('Password too short');\n}\nif (!name) {\n  throw new Error('Name required');\n}\n\nreturn [{ json: { email, password, name } }];"
      },
      "id": "4dcb5f48-c2bf-4430-ab37-bef5e4e3f6f6",
      "name": "Validate Input",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -128,
        0
      ]
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT id FROM users WHERE email = '{{ $json.email }}' LIMIT 1",
        "options": {}
      },
      "id": "f79e4bb1-1d96-4624-8756-ed7ca702cde9",
      "name": "Check Email Exists",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.4,
      "position": [
        288,
        0
      ]
    },
    {
      "parameters": {
        "jsCode": "const bcrypt = require('bcryptjs');\nconst password = $('Validate Input').first().json.password;\nconst hash = bcrypt.hashSync(password, 8);\nconst code = String(Math.floor(100000 + Math.random() * 900000));\nreturn [{ json: { password_hash: hash, code } }];"
      },
      "id": "32d756d1-a780-465d-8756-3fc0ea72f840",
      "name": "Hash Password",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
