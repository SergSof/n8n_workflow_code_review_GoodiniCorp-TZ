      ]
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "INSERT INTO users (email, password_hash) VALUES ('{{ $json.body.email }}', '{{ $json.password_hash }}') RETURNING id",
        "options": {}
      },
