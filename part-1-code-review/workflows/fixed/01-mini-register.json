        "query": "INSERT INTO users (email, password_hash, name)\nVALUES (\n  '{{ $(\"Validate Input\").first().json.email }}',\n  '{{ $json.password_hash }}',\n  '{{ $(\"Validate Input\").first().json.name }}'\n)\nRETURNING id;",
        "options": {}
