        }
      }
    },
    {
      "parameters": {
        "jsCode": "const password = $('Validate Input').first().json.password;\n\nconst hash = `test_hash_${password}`;\nconst code = String(Math.floor(100000 + Math.random() * 900000));\n\nreturn [\n  {\n    json: {\n      password_hash: hash,\n      code,\n    },\n  },\n];"
      },
      "id": "1d138c3c-35c0-41d8-8d9b-5435724ea0e3",
