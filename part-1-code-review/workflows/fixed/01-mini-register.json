    {
      "parameters": {
        "jsCode": "const body = $input.first().json.body || {};\nconst email = (body.email || '').trim().toLowerCase();\nconst password = body.password || '';\nconst name = body.name || '';\n\nif (!email || !email.includes('@')) {\n  throw new Error('Invalid email');\n}\nif (password.length < 6) {\n  throw new Error('Password too short');\n}\nif (!name) {\n  throw new Error('Name required');\n}\n\nreturn [{ json: { email, password, name } }];"
      },
      "id": "ac425f99-ada7-4cb5-8134-ecb4d35d5598",
      "name": "Validate Input",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        64,
        0
      ]
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT EXISTS (\n  SELECT 1\n  FROM users\n  WHERE email = '{{ $json.email }}'\n) AS email_exists;",
        "options": {}
      },
      "id": "fdb46222-5904-4044-b224-a66e91502612",
      "name": "Check Email Exists",
